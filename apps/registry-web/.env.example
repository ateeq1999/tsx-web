# tsx registry-web — Environment Variables
# Copy to .env for local development. Never commit .env.

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/registry_web

# ── Auth (better-auth) ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate-a-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:3000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Trusted origin for server-side CORS (no VITE_ prefix — not exposed to browser)
CORS_ORIGIN=http://localhost:3000

# ── GitHub OAuth (optional — enables "Sign in with GitHub") ───────────────────
# Create a GitHub OAuth App: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://your-vercel-url/api/auth/callback/github (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth (optional — enables "Sign in with Google") ───────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (dev)
#                          https://your-vercel-url/api/auth/callback/google (prod)
# Note: GITHUB_CLIENT_ID must also be set (Google is nested inside socialProviders)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Registry backend URL ───────────────────────────────────────────────────────
VITE_REGISTRY_URL=http://localhost:8080

# ── Server URL (used for SSR and auth callbacks) ───────────────────────────────
VITE_SERVER_URL=http://localhost:3000

# ── Site URL ───────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://registry.tsx.dev

# ── Sentry error monitoring (optional) ─────────────────────────────────────────
# Create a project at https://sentry.io — free tier is sufficient.
# Leave blank to disable Sentry (errors are still shown in the console).
VITE_SENTRY_DSN=
