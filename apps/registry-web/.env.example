# tsx registry-web — Environment Variables
# Copy to .env for local development. Never commit .env.

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/registry_web

# ── Auth (better-auth) ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate-a-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:3000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Trusted origin for server-side CORS (no VITE_ prefix — not exposed to browser)
CORS_ORIGIN=http://localhost:3000

# ── GitHub OAuth (optional — enables "Sign in with GitHub") ───────────────────
# Create a GitHub OAuth App: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://your-vercel-url/api/auth/callback/github (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Registry backend URL ───────────────────────────────────────────────────────
VITE_REGISTRY_URL=http://localhost:8080

# ── Server URL (used for SSR and auth callbacks) ───────────────────────────────
VITE_SERVER_URL=http://localhost:3000

# ── Site URL ───────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://registry.tsx.dev
