{
  "name": "tsx-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --cwd apps/registry-web dev",
    "dev:docs": "bun --cwd apps/docs dev",
    "build:web": "cd apps/registry-web && NITRO_PRESET=vercel bun run build",
    "build:docs": "cd apps/docs && NITRO_PRESET=vercel bun run build",
    "deploy:web": "vercel deploy --prebuilt --cwd apps/registry-web --scope ateeq1999s-projects --yes",
    "deploy:web:prod": "vercel deploy --prebuilt --cwd apps/registry-web --scope ateeq1999s-projects --prod --yes",
    "deploy:docs": "vercel deploy --prebuilt --cwd apps/docs --scope ateeq1999s-projects --yes",
    "deploy:docs:prod": "vercel deploy --prebuilt --cwd apps/docs --scope ateeq1999s-projects --prod --yes",
    "deploy:all:prod": "bun run build:web && bun run deploy:web:prod && bun run build:docs && bun run deploy:docs:prod"
  }
}
